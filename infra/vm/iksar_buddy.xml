<!--
  libvirt domain for the iksar_buddy guest (Windows 10 Pro, EQ2 client host).
  Opsec (§7.5): domain name is "iksar_buddy" — nothing reads "eq2"/"bot".

  Hardware notes:
    - q35 + UEFI (OVMF, secure-boot off) — firmware auto-selected by libvirt.
    - 8 GB RAM with virtio balloon so the host can reclaim under pressure
      (host is RAM-tight; Satisfactory + AI work share the box).
    - 8 vCPUs, host-passthrough, PINNED to P-core threads cpu0-7 (i7-13700K:
      P-cores=cpu0-15 HT pairs, E-cores=cpu16-23). Guest topology 4c/2t maps
      onto 4 physical P-cores. Emulator + iothread pinned to E-cores (cpu16-17)
      so QEMU's own threads never preempt a vCPU. Leaves cpu8-23 (16 threads)
      for the host's 4070 AI work + other VMs — do NOT widen the pin set.
    - OS disk on SATA (qcow2). virtio-blk would need a driver injected into
      WinPE; SATA is plenty for a 2004 client and keeps install trivial.
    - NIC is virtio — no in-box Win10 driver, so it's dead during OOBE
      (forces offline install). Bring it up via NetKVM after first boot.
    - QXL video + SPICE. Connect from your workstation with:
        virt-viewer -c qemu+ssh://jbaker@10.0.0.16/system iksar_buddy
      SPICE listens on loopback only; virt-viewer tunnels it over SSH.
    - CD-ROMs: [0] Windows ISO (boot), [1] virtio-win, [2] autounattend.
      Detach all three after install is done.
-->
<domain type="kvm">
  <name>iksar_buddy</name>
  <title>iksar_buddy</title>
  <memory unit="GiB">8</memory>
  <currentMemory unit="GiB">8</currentMemory>
  <vcpu placement="static">8</vcpu>
  <cputune>
    <vcpupin vcpu="0" cpuset="0"/>
    <vcpupin vcpu="1" cpuset="1"/>
    <vcpupin vcpu="2" cpuset="2"/>
    <vcpupin vcpu="3" cpuset="3"/>
    <vcpupin vcpu="4" cpuset="4"/>
    <vcpupin vcpu="5" cpuset="5"/>
    <vcpupin vcpu="6" cpuset="6"/>
    <vcpupin vcpu="7" cpuset="7"/>
    <emulatorpin cpuset="16-17"/>
  </cputune>
  <os firmware="efi">
    <type arch="x86_64" machine="q35">hvm</type>
    <firmware>
      <feature enabled="no" name="secure-boot"/>
    </firmware>
    <boot dev="cdrom"/>
    <boot dev="hd"/>
  </os>
  <features>
    <acpi/>
    <apic/>
    <hyperv mode="custom">
      <relaxed state="on"/>
      <vapic state="on"/>
      <spinlocks state="on" retries="8191"/>
      <vpindex state="on"/>
      <runtime state="on"/>
      <synic state="on"/>
      <stimer state="on"/>
      <frequencies state="on"/>
    </hyperv>
    <vmport state="off"/>
  </features>
  <cpu mode="host-passthrough" check="none" migratable="off">
    <topology sockets="1" dies="1" cores="4" threads="2"/>
  </cpu>
  <clock offset="localtime">
    <timer name="rtc" tickpolicy="catchup"/>
    <timer name="pit" tickpolicy="delay"/>
    <timer name="hpet" present="no"/>
    <timer name="hypervclock" present="yes"/>
  </clock>
  <on_poweroff>destroy</on_poweroff>
  <on_reboot>restart</on_reboot>
  <on_crash>destroy</on_crash>
  <pm>
    <suspend-to-mem enabled="no"/>
    <suspend-to-disk enabled="no"/>
  </pm>
  <devices>
    <emulator>/usr/bin/qemu-system-x86_64</emulator>

    <disk type="file" device="disk">
      <driver name="qemu" type="qcow2" discard="unmap"/>
      <source file="/var/lib/libvirt/images/iksar_buddy.qcow2"/>
      <target dev="sda" bus="sata"/>
    </disk>

    <disk type="file" device="cdrom">
      <driver name="qemu" type="raw"/>
      <source file="/var/lib/libvirt/images/ib-win10.iso"/>
      <target dev="sdb" bus="sata"/>
      <readonly/>
    </disk>
    <disk type="file" device="cdrom">
      <driver name="qemu" type="raw"/>
      <source file="/var/lib/libvirt/images/virtio-win.iso"/>
      <target dev="sdc" bus="sata"/>
      <readonly/>
    </disk>
    <disk type="file" device="cdrom">
      <driver name="qemu" type="raw"/>
      <source file="/var/lib/libvirt/images/ib-unattend.iso"/>
      <target dev="sdd" bus="sata"/>
      <readonly/>
    </disk>

    <controller type="sata" index="0"/>
    <controller type="usb" model="qemu-xhci" ports="8"/>
    <controller type="virtio-serial" index="0"/>

    <interface type="network">
      <source network="default"/>
      <model type="virtio"/>
    </interface>

    <channel type="unix">
      <target type="virtio" name="org.qemu.guest_agent.0"/>
    </channel>

    <input type="tablet" bus="usb"/>
    <input type="keyboard" bus="usb"/>

    <graphics type="spice" autoport="yes">
      <listen type="address" address="127.0.0.1"/>
      <image compression="off"/>
    </graphics>

    <!-- virtio-gpu (not QXL): QXL/qxldod only offers 4:3 modes headless; virtio
         advertises 1920x1080 via the EDID <resolution> below (viogpudo driver). -->
    <video>
      <model type="virtio" heads="1" primary="yes">
        <acceleration accel3d="no"/>
        <resolution x="1920" y="1080"/>
      </model>
    </video>

    <rng model="virtio">
      <backend model="random">/dev/urandom</backend>
    </rng>

    <memballoon model="virtio"/>

    <!-- RTX 4070 passthrough (GPU + HD-audio function). The host reserves these
         for vfio at boot (see infra/host/PASSTHROUGH.md), so 'managed' finds them
         already on vfio-pci. EQ2 renders on the 4070 (per-app GpuPreference=2) and
         DWM composites the result back to the virtio-gpu display above -- so SPICE
         and `virsh screenshot` (the bot's host-side sensors) still see the game.
         The 4070 audio is passed too so the GPU's HDMI-audio enumerates cleanly. -->
    <hostdev mode="subsystem" type="pci" managed="yes">
      <source><address domain="0x0000" bus="0x01" slot="0x00" function="0x0"/></source>
    </hostdev>
    <hostdev mode="subsystem" type="pci" managed="yes">
      <source><address domain="0x0000" bus="0x01" slot="0x00" function="0x1"/></source>
    </hostdev>
  </devices>
</domain>
