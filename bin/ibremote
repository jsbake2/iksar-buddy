#!/usr/bin/env bash
# ibremote — connect to an ib guest VM from this workstation.
#
# Handles MULTIPLE VMs (the future crafting fleet): pick by name, by interactive
# menu, or --all. Auto-discovers each guest's IP via libvirt (qemu-agent, then
# DHCP lease by MAC). Two transports:
#
#   rdp      (default) SSH-tunnel the guest's 3389 -> a per-VM local port, then
#            xfreerdp. Needs the guest's NIC up + RDP enabled. Encrypted, no
#            changes to the host network.
#   console  SPICE console via virt-viewer over qemu+ssh. Works for ANY defined
#            VM regardless of guest networking (good for a fresh crafting VM
#            before RDP is set up).
#
# Usage:
#   ibremote                 # rdp; one VM -> connect, many -> menu
#   ibremote <vm>            # rdp to a named VM
#   ibremote -c [<vm>]       # SPICE console instead of RDP
#   ibremote -l              # list running VMs + discovered IPs
#   ibremote -a              # rdp to ALL running VMs (one window each)
#
# Env: IB_HOST (default 10.0.0.16), IB_SSH_USER (default jbaker),
#      IB_RUSER/IB_RPASS (guest RDP creds; default iksar / IksarBuddy1!)
set -euo pipefail

HOST="${IB_HOST:-10.0.0.16}"
SSH_USER="${IB_SSH_USER:-jbaker}"
RUSER="${IB_RUSER:-iksar}"
RPASS="${IB_RPASS:-IksarBuddy1!}"

MODE="rdp"; WANT=""; ALL=0
while [ $# -gt 0 ]; do
  case "$1" in
    -c|--console) MODE="console" ;;
    -r|--rdp)     MODE="rdp" ;;
    -l|--list)    MODE="list" ;;
    -a|--all)     ALL=1 ;;
    -h|--help)    sed -n '2,30p' "$0"; exit 0 ;;
    -*)           echo "unknown option: $1" >&2; exit 2 ;;
    *)            WANT="$1" ;;
  esac
  shift
done

ssh_h() { ssh -o BatchMode=yes "${SSH_USER}@${HOST}" "$@"; }
vsys()  { ssh_h "sudo -n virsh -c qemu:///system $*"; }

list_running() { vsys list --state-running --name | sed '/^[[:space:]]*$/d'; }

discover_ip() {  # $1=vm -> prints IP or empty
  local vm="$1" ip mac
  ip=$(vsys domifaddr "$vm" --source agent 2>/dev/null \
       | awk '/ipv4/{print $4}' | cut -d/ -f1 | head -1) || true
  if [ -z "${ip:-}" ]; then
    mac=$(vsys domiflist "$vm" 2>/dev/null | awk 'NR>2 && $5 ~ /:/ {print $5; exit}')
    ip=$(vsys net-dhcp-leases default 2>/dev/null \
         | awk -v m="$mac" 'tolower($3)==tolower(m){print $5}' | cut -d/ -f1 | head -1) || true
  fi
  echo "${ip:-}"
}

local_port() {  # stable per-VM port so multiple tunnels don't collide
  echo $(( 13389 + ( $(echo -n "$1" | cksum | cut -d' ' -f1) % 2000 ) ))
}

rdp_bin() { command -v xfreerdp3 || command -v xfreerdp || true; }

pick_vm() {
  local -a vms; mapfile -t vms < <(list_running)
  [ ${#vms[@]} -gt 0 ] || { echo "no running VMs on $HOST" >&2; exit 1; }
  if [ -n "$WANT" ]; then printf '%s\n' "${vms[@]}" | grep -qx "$WANT" \
       && { echo "$WANT"; return; } || { echo "VM '$WANT' not running" >&2; exit 1; }; fi
  [ ${#vms[@]} -eq 1 ] && { echo "${vms[0]}"; return; }
  echo "running VMs:" >&2; local i=1; for v in "${vms[@]}"; do echo "  $i) $v" >&2; i=$((i+1)); done
  read -rp "pick #: " n; echo "${vms[$((n-1))]}"
}

connect_rdp() {
  local vm="$1" ip port bin
  ip=$(discover_ip "$vm"); [ -n "$ip" ] || { echo "[$vm] no IP found (NIC up?)" >&2; return 1; }
  port=$(local_port "$vm"); bin=$(rdp_bin)
  [ -n "$bin" ] || { echo "no xfreerdp — install: sudo pacman -S freerdp" >&2; return 1; }
  echo "[$vm] $ip  tunnel 127.0.0.1:$port -> $ip:3389"
  ssh -fN -o ExitOnForwardFailure=yes -L "${port}:${ip}:3389" "${SSH_USER}@${HOST}" || true
  local tpid; tpid=$(pgrep -f "L ${port}:${ip}:3389" | head -1 || true)
  "$bin" /v:127.0.0.1:${port} /u:"$RUSER" /p:"$RPASS" /cert:ignore /dynamic-resolution +clipboard /title:"$vm" 2>/dev/null \
    || "$bin" /v:127.0.0.1:${port} /u:"$RUSER" /p:"$RPASS" /cert-ignore /dynamic-resolution 2>/dev/null || true
  [ -n "${tpid:-}" ] && kill "$tpid" 2>/dev/null || true
}

connect_console() {
  local vm="$1"
  command -v virt-viewer >/dev/null || { echo "no virt-viewer — install: sudo pacman -S virt-viewer" >&2; return 1; }
  echo "[$vm] SPICE console over qemu+ssh"
  virt-viewer --connect "qemu+ssh://${SSH_USER}@${HOST}/system" "$vm" &
}

case "$MODE" in
  list)
    printf '%-22s %s\n' "VM" "IP"
    while read -r vm; do printf '%-22s %s\n' "$vm" "$(discover_ip "$vm")"; done < <(list_running)
    ;;
  console)
    if [ "$ALL" = 1 ]; then while read -r vm; do connect_console "$vm"; done < <(list_running); wait
    else connect_console "$(pick_vm)"; fi ;;
  rdp)
    if [ "$ALL" = 1 ]; then while read -r vm; do connect_rdp "$vm" || true; done < <(list_running)
    else connect_rdp "$(pick_vm)"; fi ;;
esac
